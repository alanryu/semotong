<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.co.ucomp.web.svc.randing.mapper.InternetRdpMngMapper">

    <sql id="listWhereInfo">
        <if test='searchUseYn != null and searchUseYn !=""'>
            AND use_yn = #{searchUseYn}
        </if>
        
              <!-- 등록일 조회-->
        <if test='searchStartDt != null and searchStartDt !=""'>
            AND create_date  <![CDATA[>=]]> #{searchStartDt}
        </if>
        <if test='searchEndDt != null and searchEndDt !=""'>
            AND create_date <![CDATA[<=]]> #{searchEndDt}
        </if>
        
        <if test='keyword != null and keyword !=""'>
			AND title LIKE CONCAT('%', #{keyword}, '%') 
		</if>
			
        
    </sql>
		
	<sql id="Base_Column_list_Info">
		id
		,title
		,top_banner
		,foot_banner
		,foot_bar_text
		,btn_cta
		,btn_color
		,use_yn
		,rd_url
		,create_date
		,create_id
		,modified_date
		,modified_id
		,GET_ADMIN_USER_NM(create_id) as createNm
		,GET_ADMIN_USER_NM(modified_id) as modifiedNm 
				
	</sql>

    <select id="list" parameterType="kr.co.ucomp.web.svc.randing.dto.InternetRdpMngSearchDto" resultType="kr.co.ucomp.web.svc.randing.entity.InternetRdpMngEntity">
        SELECT
           <include refid="Base_Column_list_Info" />
        FROM
            tb_pmb_internet_rdp
        WHERE 1=1
        <include refid="listWhereInfo"/>
        ORDER BY create_date DESC
    </select>


	<select id="count" parameterType="kr.co.ucomp.web.svc.randing.dto.InternetRdpMngSearchDto" resultType="java.lang.Long">
		SELECT COUNT(1)
		FROM tb_pmb_internet_rdp
		WHERE 1=1
		<include refid="listWhereInfo" />
	</select>
	
	
	<select id="getDetail" parameterType="int" resultType="kr.co.ucomp.web.svc.randing.entity.InternetRdpMngEntity">
		SELECT
			<include refid="Base_Column_list_Info" />
		FROM tb_pmb_internet_rdp
		WHERE id = #{id}
	</select>
	    

    <insert id="create" parameterType="kr.co.ucomp.web.svc.randing.entity.InternetRdpMngEntity" useGeneratedKeys="true" keyProperty="id" keyColumn="id">
         INSERT INTO tb_pmb_internet_rdp (
            title, 
            top_banner, 
            foot_banner, 
            foot_bar_text, 
            btn_cta, 
            btn_color, 
            use_yn, 
            rd_url, 
            create_id
        ) VALUES (
            #{title}, 
            #{topBanner}, 
            #{footBanner}, 
            #{footBarText}, 
            #{btnCta}, 
            #{btnColor}, 
            #{useYn}, 
            #{rdUrl}, 
            #{createId} 
        )
    </insert>


    <!-- Update -->
    <update id="update" parameterType="kr.co.ucomp.web.svc.randing.entity.InternetRdpMngEntity">
        UPDATE tb_pmb_internet_rdp
        SET 
            title = #{title},
            top_banner = #{topBanner},
            foot_banner = #{footBanner},
            foot_bar_text = #{footBarText},
            btn_cta = #{btnCta},
            btn_color = #{btnColor},
            use_yn = #{useYn},
            rd_url = #{rdUrl},
            modified_date = NOW(),
            modified_id = #{modifiedId}
        WHERE 
            id = #{id}
    </update>
    
    
        <!-- updateUseYn -->
    <update id="updateEx" parameterType="kr.co.ucomp.web.svc.randing.entity.InternetRdpMngEntity">
        UPDATE tb_pmb_internet_rdp
        SET 
        	modified_date = NOW(),
        	<if test='useYn != null and useYn !=""'>
            use_yn = #{useYn},
            </if>
            <if test='rdUrl != null and rdUrl !=""'>
            rd_url = #{rdUrl},
            </if>
            modified_id = #{modifiedId}
        WHERE 
            id = #{id}
    </update>
    


    <delete id="delete" parameterType="Int">
        DELETE FROM tb_pmb_internet_rdp
        WHERE id = #{id}
    </delete>


</mapper>