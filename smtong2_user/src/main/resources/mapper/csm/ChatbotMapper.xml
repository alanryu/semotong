<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.co.ucomp.web.chatbot.mapper.ChatbotMapper">

    <sql id="base_column">
        id,
        plan,
        plan_memo,
        order_seq,
        create_date,
        create_id,
        modified_date,
        modified_id
    </sql>


    <!-- 전체 조회 -->
    <select id="getChatbotPlanList"  parameterType="kr.co.ucomp.web.chatbot.dto.ChatbotMainPlanDTO" resultType="kr.co.ucomp.web.chatbot.entity.ChatbotGroupPlanEntity">
        SELECT <include refid="base_column"/>
        FROM tb_svc_chatbot_group_plan
        ORDER BY order_seq ASC
    </select>

    <!-- ID로 단일 조회 -->
    <select id="getChatbotPlanListById" parameterType="int" resultType="kr.co.ucomp.web.chatbot.entity.ChatbotGroupPlanEntity">
        SELECT <include refid="base_column"/>
        FROM tb_svc_chatbot_group_plan
        WHERE id = #{id}
    </select>

</mapper>
