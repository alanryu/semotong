<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.co.ucomp.web.cmm.mapper.CommCodeMngMapper">

	<sql id="listWhere">
			<if test='userYn != null and userYn !=""'>
				AND use_yn = #{userYn}
			</if>
			
			<if test='codeGroup != null and codeGroup !=""'>
				AND code_group = #{codeGroup}
			</if>
	</sql>
	
	<!--  ========================================= code group manage ============================================================ -->
	<sql id="Base_Column_list_Group">
		code_group
		,code_group_name
		,code_group_desc
		,use_yn
		,create_date
		,create_id
		,GET_ADMIN_USER_NM(create_id) as createNm
		,modified_date
		,modified_id
		,GET_ADMIN_USER_NM(modified_id) as modifiedNm
				
	</sql>
	
	<select id="getListCodeGroup" parameterType="kr.co.ucomp.web.cmm.dto.CommCodeSearchDto" resultType="kr.co.ucomp.web.cmm.entity.CodeGroupEntity">
		  SELECT
	            <include refid="Base_Column_list_Group" />
	        FROM
	            tb_cmm_code_group
	        WHERE 1=1
	        <include refid="listWhere" />
	        ORDER BY code_group
	        LIMIT #{offset}, #{recordSize}

	</select>

	<select id="getListCodeGroupCount" parameterType="kr.co.ucomp.web.cmm.dto.CommCodeSearchDto" resultType="Long">
		  SELECT
	            count(1)
	        FROM
	            tb_cmm_code_group
	        WHERE 1=1
	        <include refid="listWhere" />
	</select>
	
	
	<select id="getCodeGroup" parameterType="map" resultType="kr.co.ucomp.web.cmm.entity.CodeGroupEntity">
		SELECT
	            <include refid="Base_Column_list_Group" />
	        FROM
	            tb_cmm_code_group
	        WHERE code_group=#{codeGroup}
	</select>

	
	
	
	<!--  ========================================= code manage ============================================================ -->
	
	
	<sql id="listCodeWhere">
			<if test='userYn != null and userYn !=""'>
				AND use_yn = #{userYn}
			</if>
			
			<if test='codeGroup != null and codeGroup !=""'>
				AND code_group = #{codeGroup}
			</if>
			
			<if test='code != null and code !=""'>
				AND code = #{code}
			</if>
			
			<if test='etc1 != null and etc1 !=""'>
				AND etc1 = #{etc1}
			</if>
			
			<if test='etc2 != null and etc2 !=""'>
				AND etc2 = #{etc2}
			</if>
			
			<if test='etc3 != null and etc3 !=""'>
				AND etc3 = #{etc3}
			</if>
			
			<if test='etc4 != null and etc4 !=""'>
				AND etc4 = #{etc4}
			</if>
						
	</sql>
	
	
	<sql id="Base_Column_list_Code">
		code_group
		,code
		,code_name
		,code_desc
		,order_no
		,etc1
		,etc2
		,etc3
		,etc4
		,etc5
		,use_yn
		,create_date
		,create_id
		,GET_ADMIN_USER_NM(create_id) as createNm
		,modified_date
		,modified_id
		,GET_ADMIN_USER_NM(modified_id) as modifiedNm
	</sql>
	
	<select id="getListCode" parameterType="kr.co.ucomp.web.cmm.dto.CommCodeSearchDto" resultType="kr.co.ucomp.web.cmm.entity.CodeEntity">
		  SELECT
	            <include refid="Base_Column_list_Code" />
	        FROM
	            tb_cmm_code
	        WHERE 1=1
	        <include refid="listCodeWhere" />
			ORDER BY order_no, code_group,code
	        LIMIT #{offset}, #{recordSize}

	</select>

	<select id="getListCodeCount" parameterType="kr.co.ucomp.web.cmm.dto.CommCodeSearchDto" resultType="Long">
		  SELECT
	            count(1)
	        FROM
	            tb_cmm_code
	        WHERE 1=1
	        <include refid="listCodeWhere" />
	</select>
	
	
	<select id="getCode" parameterType="kr.co.ucomp.web.cmm.dto.CommCodeSearchDto" resultType="kr.co.ucomp.web.cmm.entity.CodeEntity">
		SELECT
	            <include refid="Base_Column_list_Code" />
	        FROM
	            tb_cmm_code
	        WHERE 1=1
	        <include refid="listCodeWhere" />
	</select>

	
	
</mapper>